# apps/jobs needs DB access via the service-role key to verify workspace
# context before running any task. Per CLAUDE.md, service-role usage is
# allowed in Trigger.dev tasks BUT each task must assert workspace context
# (via private.is_workspace_member or an equivalent narrow lookup).
#
# Local: copy to apps/jobs/.env and populate from `supabase status -o env`
#        — map API_URL → SUPABASE_URL, SERVICE_ROLE_KEY → SUPABASE_SERVICE_ROLE_KEY.
# Deployed: set these as project env vars in your Trigger.dev dashboard.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Trigger.dev project reference. Get one by running:
#   npx trigger.dev@latest login
#   npx trigger.dev@latest init
# (or via the Trigger.dev cloud/self-hosted dashboard) and pasting the
# proj_* string here.
TRIGGER_PROJECT_REF=

# Optional: SDK log level inside tasks.
TRIGGER_LOG_LEVEL=info
