# Copy to apps/web/.env.local and fill in values for local dev.
# .env.local is gitignored at the repo root.

# --- Supabase (required) ----------------------------------------------------
# For local Supabase: run `supabase start` from the repo root, then
# `supabase status -o env` and copy ANON_KEY / API_URL here.
# For staging/prod: paste from the Supabase project's API settings page.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only key. Required for any code path that intentionally bypasses
# RLS (none in Sprint 01). Leave unset locally if you don't need it.
SUPABASE_SERVICE_ROLE_KEY=

# --- Sentry (optional; SDK no-ops without these) ----------------------------
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
# Build-time only; required to upload source maps to Sentry. Skip locally.
SENTRY_AUTH_TOKEN=

# --- Axiom (optional; logger no-ops without these) --------------------------
AXIOM_TOKEN=
AXIOM_DATASET=

# --- Stripe (required for /api/webhooks/stripe; Sprint 12+ for outbound API) -
# STRIPE_SECRET_KEY: test or live key from Stripe Dashboard. The webhook
# route requires it because the Stripe SDK constructor refuses to start
# without one — even though signature verification itself doesn't use it.
# Use a test-mode key during Sprint 01.
STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET: the signing secret. For local dev:
#   stripe listen --forward-to localhost:3000/api/webhooks/stripe
# prints a `whsec_...` value — paste it here. For staging/prod, copy from
# the Stripe Dashboard → Developers → Webhooks → endpoint signing secret.
STRIPE_WEBHOOK_SECRET=
