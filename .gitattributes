# Excluded from `git archive` tarballs (proprietary carve-out + dev-only files).
# Used so OSS distributions built with `git archive` do not ship hosted-only code.
packages/hosted-features export-ignore
LICENSE-PROPRIETARY     export-ignore
.github                 export-ignore
.gitattributes          export-ignore
.gitignore              export-ignore

# Line endings + binary file handling
* text=auto eol=lf
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.webp binary
*.pdf  binary
*.docx binary
*.xlsx binary
*.zip  binary
