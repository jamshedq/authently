{
  "name": "authently",
  "private": true,
  "version": "0.0.0",
  "description": "Authently — open-source, multi-tenant AI content engine.",
  "homepage": "https://authently.io",
  "license": "AGPL-3.0-or-later",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:db": "pnpm --filter @authently/db test:db",
    "test:rls": "pnpm --filter @authently/db test:rls",
    "test:auth": "pnpm --filter @authently/db test:auth",
    "test:billing": "pnpm --filter @authently/db test:billing",
    "test:web": "pnpm --filter @authently/web test:web",
    "test:jobs": "pnpm --filter @authently/jobs test:jobs",
    "test:license-headers": "node scripts/check-license-headers.mjs",
    "typecheck": "turbo run typecheck",
    "db:migrate": "supabase migration up",
    "db:reset": "supabase db reset",
    "db:gen-types": "pnpm --filter @authently/db gen:types",
    "db:new": "pnpm --filter @authently/db run new"
  },
  "devDependencies": {
    "turbo": "^2.3.3"
  }
}
