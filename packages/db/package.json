{
  "name": "@authently/db",
  "version": "0.0.0",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./types.ts"
  },
  "scripts": {
    "gen:types": "tsx scripts/generate-types.ts",
    "new": "tsx scripts/new-migration.ts",
    "lint": "echo 'lint not yet wired (Sprint 01, Step 4)' && exit 0",
    "test": "echo 'no non-RLS tests in @authently/db yet (run pnpm test:rls for the RLS gate)' && exit 0",
    "test:db": "vitest run",
    "test:rls": "vitest run --project rls",
    "test:auth": "vitest run --project auth",
    "test:billing": "vitest run --project billing",
    "test:sources": "vitest run --project sources",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@supabase/supabase-js": "^2.45.4",
    "@types/node": "^22.10.0",
    "dotenv": "^16.4.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^3.0.5"
  }
}
