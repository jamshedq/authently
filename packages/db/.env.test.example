# Copy to packages/db/.env.test for local test runs.
# .env.test is gitignored (root .gitignore).
#
# Populate by running:
#   supabase start
#   supabase status -o env
#
# Map the printed keys (API_URL, ANON_KEY, SERVICE_ROLE_KEY) into the names
# below. CI populates these the same way via supabase/setup-cli@v1.

SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
